{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      // 1. Sipariş Rotası
      "order_route": {
        "ClusterId": "order_cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      // 2. Kurye Takip Rotası
      "tracking_route": {
        "ClusterId": "tracking_cluster",
        "Match": {
          "Path": "/api/tracking/{**catch-all}"
        }
      },
      // 3. SignalR Canlı Yayın Rotası
      "notification_route": {
        "ClusterId": "notification_cluster",
        "Match": {
          "Path": "/logisticsHub/{**catch-all}"
        }
      }
    },
    "Clusters": {
      // Sipariş Servisi Hedefi
      "order_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7090"
          }
        }
      },
      // Kurye Takip Servisi Hedefi
      "tracking_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7219"
          }
        }
      },
      // Bildirim Servisi Hedefi (SignalR portun hangisiyse onunla güncelleyebilirsin)
      "notification_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7254"
          }
        }
      }
    }
  }
}